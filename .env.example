# LoreKit — Environment Configuration

# --- Database (required) ---
DATABASE_URL=postgresql://localhost:5432/lorekit

# --- LLM (required — pick one) ---
OPENAI_API_KEY=sk-xxx
# ANTHROPIC_API_KEY=sk-ant-xxx

# LLM provider: "openai" or "anthropic"
LLM_PROVIDER=openai
LLM_MODEL=gpt-5.4
# Cheaper alternative for metadata generation: gpt-5.4-mini

# --- Video Generation (required) ---
FAL_KEY=xxx
# Get a key at https://fal.ai/dashboard/keys

# --- YouTube (optional — for auto-publishing) ---
# YOUTUBE_CLIENT_SECRET_PATH=./client_secret.json

# --- Frontend (defaults are fine for local dev) ---
# Backend API URL (Next.js → FastAPI)
# NEXT_PUBLIC_API_URL=http://localhost:8001

# --- Cloud mode (optional — leave commented for open-source single-user) ---
# Uncomment these to enable auth, multi-tenancy, and org support:
# BETTER_AUTH_SECRET=your-secret-here
# BETTER_AUTH_URL=http://localhost:3001
# NEXT_PUBLIC_BETTER_AUTH_URL=http://localhost:3001

# --- Billing (optional — leave commented for open-source unlimited mode) ---
# Uncomment to enable Stripe billing, credit metering, and subscriptions:
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# APP_URL=http://localhost:3001
# NEXT_PUBLIC_STRIPE_TEST_MODE=true

# --- Paths (defaults are fine for local dev) ---
# OUTPUT_DIR=./output
# CLIPS_DIR=./clips
# AUDIO_ASSETS_DIR=./lorekit/audio/assets
